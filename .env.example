# LiveKit Configuration
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_URL=wss://your-project.livekit.cloud

# Free-Tier AI Providers (no credit card required)
# Get your free API keys:
#   - OpenRouter (LLM): https://openrouter.ai/settings/keys
#   - Deepgram (STT): https://console.deepgram.com - $200 free credits
#   - Cartesia (TTS): https://play.cartesia.ai - 10,000 free credits

OPENROUTER_API_KEY=your_openrouter_api_key
DEEPGRAM_API_KEY=your_deepgram_api_key
CARTESIA_API_KEY=your_cartesia_api_key

# Optional: Groq API (for future use)
# GROQ_API_KEY=your_groq_api_key

# =============================================================================
# OpenRouter LLM Configuration
# =============================================================================

# Model to use (overrides config/medical_triage.json)
#
# RECOMMENDED MODELS:
#   - google/gemini-3-flash-preview (DEFAULT - excellent tool support, fast)
#   - google/gemini-2.0-flash-exp:free (free tier alternative)
#   - mistralai/mistral-small-3.1-24b-instruct:free (good, needs provider exclusions)
#
# PAID MODELS (if needed):
#   - deepseek/deepseek-chat (~$0.14/1M tokens)
#   - openai/gpt-4o-mini (~$0.15/1M tokens)
#
# DO NOT USE (no tool_choice support):
#   - xiaomi/mimo-v2-flash:free
#   - openai/gpt-oss-120b:free
#   - meta-llama/llama-3.3-70b-instruct:free (partial support only)
#
OPENROUTER_MODEL=google/gemini-3-flash-preview

# Fallback models if primary is unavailable (comma-separated)
# OPENROUTER_FALLBACK_MODELS=anthropic/claude-sonnet-4,openai/gpt-4o-mini

# Analytics (optional)
# OPENROUTER_SITE_URL=https://myapp.com
# OPENROUTER_APP_NAME=Medical Triage System

# =============================================================================
# Provider Routing Configuration
# =============================================================================

# Providers to EXCLUDE (comma-separated) - Use to avoid problematic providers
# Known issues: Venice (malformed JSON), ModelRun (no streaming tool support)
OPENROUTER_PROVIDER_IGNORE=Venice,ModelRun

# Providers to EXCLUSIVELY use (comma-separated)
# OPENROUTER_PROVIDER_ONLY=google,anthropic

# Preferred provider ORDER (comma-separated)
# OPENROUTER_PROVIDER_ORDER=google,anthropic,openai

# Sort providers by: price, throughput, or latency
OPENROUTER_PROVIDER_SORT=latency

# Allow fallback to other providers if preferred ones fail
OPENROUTER_ALLOW_FALLBACKS=true

# Only use providers that support ALL parameters (tools, tool_choice, etc.)
# Enable this to avoid "tool_choice not supported" errors with some models
OPENROUTER_REQUIRE_PARAMETERS=true

# Data collection preference: allow or deny
# OPENROUTER_DATA_COLLECTION=deny

# Maximum price per token (e.g., 0.001)
# OPENROUTER_MAX_PRICE=0.001

# Accepted quantization levels (comma-separated, e.g., fp16,fp8)
# OPENROUTER_QUANTIZATIONS=fp16,fp8

# =============================================================================
# Context Management Configuration
# =============================================================================

# Compaction threshold - compact context when token usage exceeds this percentage
# of the model's context window. Lower = more aggressive compaction.
# Range: 0.1 to 0.9 (10% to 90%)
# Default: 0.40 (40%)
CONTEXT_COMPACTION_THRESHOLD=0.40

# Compact target - target percentage to compact DOWN TO after threshold is triggered.
# This determines how much context to retain after LLM summarization.
# Range: 0.05 to 0.50 (5% to 50%)
# Default: 0.20 (20%)
CONTEXT_COMPACT_TARGET=0.20

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite database path for cross-call patient memory
# Default: data/sessions.db
DATABASE_PATH=data/sessions.db

# =============================================================================
# Optional Configuration
# =============================================================================

# Configuration file path (default: config/medical_triage.json)
CONFIG_FILE_PATH=config/medical_triage.json

# Optional: OpenAI (if you prefer paid OpenAI instead of OpenRouter)
# OPENAI_API_KEY=your_openai_api_key
